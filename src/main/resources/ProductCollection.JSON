{
        "info": {
        "name": "Monate Retail - Catalog API",
        "description": "Endpoints for retrieving products, single manual entry, bulk JSON API, and CSV File upload.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
        },
        "item": [
        {
        "name": "1. Read: Get Products (Paginated)",
        "request": {
        "method": "GET",
        "header": [],
        "url": {
        "raw": "http://localhost:8080/api/v1/catalog/products?page=0&size=2&sortBy=name",
        "protocol": "http",
        "host": [
        "localhost"
        ],
        "port": "8080",
        "path": [
        "api",
        "v1",
        "catalog",
        "products"
        ],
        "query": [
        {
        "key": "page",
        "value": "0",
        "description": "Page number (starts at 0)"
        },
        {
        "key": "size",
        "value": "2",
        "description": "Items per page"
        },
        {
        "key": "sortBy",
        "value": "name",
        "description": "Field to sort by"
        }
        ]
        }
        },
        "response": []
        },
        {
        "name": "2. Ingest: Manual UI Entry (Single Product)",
        "request": {
        "method": "POST",
        "header": [
        {
        "key": "Content-Type",
        "value": "application/json"
        }
        ],
        "body": {
        "mode": "raw",
        "raw": "{\n  \"categorySlug\": \"summer-braai\",\n  \"baseSku\": \"CHARCOAL-001\",\n  \"name\": \"Premium Briquettes\",\n  \"description\": \"Long burning charcoal briquettes.\"\n}"
        },
        "url": {
        "raw": "http://localhost:8080/api/v1/catalog/product",
        "protocol": "http",
        "host": [
        "localhost"
        ],
        "port": "8080",
        "path": [
        "api",
        "v1",
        "catalog",
        "product"
        ]
        }
        },
        "response": []
        },
        {
        "name": "3. Ingest: System-to-System EDI (Bulk JSON)",
        "request": {
        "method": "POST",
        "header": [
        {
        "key": "Content-Type",
        "value": "application/json"
        }
        ],
        "body": {
        "mode": "raw",
        "raw": "{\n  \"categorySlug\": \"groceries-beverages\",\n  \"baseSku\": \"COKE-BASE-001\",\n  \"name\": \"Coca-Cola Original Taste\",\n  \"description\": \"The classic refreshing cola.\",\n  \"variants\": [\n    {\n      \"sku\": \"COKE-CAN-330ML\",\n      \"attributes\": \"330ml Can\",\n      \"price\": 12.99,\n      \"stock\": 500\n    },\n    {\n      \"sku\": \"COKE-BTL-2L\",\n      \"attributes\": \"2 Litre Bottle\",\n      \"price\": 24.99,\n      \"stock\": 200\n    }\n  ]\n}"
        },
        "url": {
        "raw": "http://localhost:8080/api/v1/catalog/import/api",
        "protocol": "http",
        "host": [
        "localhost"
        ],
        "port": "8080",
        "path": [
        "api",
        "v1",
        "catalog",
        "import",
        "api"
        ]
        }
        },
        "response": []
        },
        {
        "name": "4. Ingest: Human Merchandiser (CSV File)",
        "request": {
        "method": "POST",
        "header": [],
        "body": {
        "mode": "formdata",
        "formdata": [
        {
        "key": "file",
        "description": "Upload your inventory.csv here",
        "type": "file",
        "src": []
        }
        ]
        },
        "url": {
        "raw": "http://localhost:8080/api/v1/catalog/import/csv",
        "protocol": "http",
        "host": [
        "localhost"
        ],
        "port": "8080",
        "path": [
        "api",
        "v1",
        "catalog",
        "import",
        "csv"
        ]
        }
        },
        "response": []
        }
        ]
        }